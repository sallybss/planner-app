{
  "name": "backend",
  "version": "1.0.0",
  "description": "mongodb express ts rest api for planner app",
  "keywords": [
    "planner",
    "api",
    "development",
    "environments"
  ],
  "repository": {
    "type": "git",
    "url": "(https://github.com/sallybss/planner-app.git)"
  },
  "nodemonConfig": {
    "verbose": false,
    "watch": [
      "src"
    ],
    "ext": "js,ts",
    "exec": "npx ts-node ./src/index.ts",
    "ignore": [
      "node_modules"
    ]
  },
  "license": "ISC",
  "author": "salibss",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --watch src --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "cross-env": "^10.1.0",
    "dotenv-flow": "^4.1.0",
    "express": "^5.2.1",
    "joi": "^18.0.2",
    "mongodb": "^7.1.0",
    "mongoose": "^9.3.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/joi": "^17.2.2",
    "@types/node": "^25.4.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
